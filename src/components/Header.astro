---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="py-8">
	<nav class="flex justify-between items-center">
		<a href={import.meta.env.BASE_URL} class="flex items-center hover:no-underline min-w-[150px]">
			<img src={import.meta.env.BASE_URL.replace(/\/$/, '') + "/logos/RSLabs.svg"} alt={SITE_TITLE} class="h-10 w-auto block" />
		</a>
		<div class="hidden md:flex flex-1 justify-end">
			<a href="https://www.malt.fr/profile/redasenouci1" target="_blank" class="text-sm font-bold text-gray-500 hover:text-cyan-500 transition-colors mr-10">Malt</a>
			<a href="https://www.linkedin.com/in/reda-senouci/" target="_blank" class="text-sm font-bold text-gray-500 hover:text-cyan-500 transition-colors">LinkedIn</a>
		</div>
	</nav>
</header>
<style>
	nav a {
		text-decoration: none;
	}
</style>
