---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="py-12 md:py-20">
		<div class="flex flex-col md:flex-row items-center gap-8">
			<div class="flex-1 text-center md:text-left">
				<h1 class="text-4xl md:text-6xl font-bold mb-4">
					Hi, I'm a <span class="text-blue-600">Software Engineer</span>
				</h1>
				<p class="text-xl text-gray-600 mb-8 max-w-2xl">
					I build high-performance web applications and share my technical journey through my blog.
				</p>
				<div class="flex flex-wrap justify-center md:justify-start gap-4">
					<a href="/blog" class="px-6 py-3 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 transition-colors">
						Read my blog
					</a>
					<a href="/about" class="px-6 py-3 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition-colors">
						About me
					</a>
				</div>
			</div>
			<div class="w-48 h-48 md:w-64 md:h-64 bg-gray-200 rounded-full flex items-center justify-center text-4xl overflow-hidden">
				<img src="/favicon.svg" alt="Profile" class="w-1/2 opacity-20" />
			</div>
		</div>
	</section>

	<section class="py-12 border-t border-gray-100">
		<h2 class="text-3xl font-bold mb-8">Technical Skills</h2>
		<div class="grid grid-cols-2 md:grid-cols-4 gap-4">
			{['Astro', 'React', 'Tailwind CSS', 'TypeScript', 'Node.js', 'Python', 'Docker', 'Git'].map((skill) => (
				<div class="p-4 bg-gray-50 rounded-lg text-center font-medium border border-gray-100">
					{skill}
				</div>
			))}
		</div>
	</section>

	<section class="py-12 border-t border-gray-100">
		<div class="flex justify-between items-center mb-8">
			<h2 class="text-3xl font-bold">Featured Projects</h2>
			<a href="https://github.com" class="text-blue-600 hover:underline">View all on GitHub &rarr;</a>
		</div>
		<div class="grid md:grid-cols-2 gap-8">
			<div class="group border border-gray-200 rounded-xl overflow-hidden hover:border-blue-400 transition-colors">
				<div class="h-48 bg-gray-100 flex items-center justify-center">
					<span class="text-gray-400 group-hover:scale-110 transition-transform">Project 1 Image</span>
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">Portfolio Website</h3>
					<p class="text-gray-600 mb-4">A fast, SEO-friendly portfolio built with Astro and Tailwind CSS.</p>
					<div class="flex gap-2">
						<span class="px-2 py-1 bg-blue-50 text-blue-600 text-xs rounded font-medium">Astro</span>
						<span class="px-2 py-1 bg-blue-50 text-blue-600 text-xs rounded font-medium">Tailwind</span>
					</div>
				</div>
			</div>
			<div class="group border border-gray-200 rounded-xl overflow-hidden hover:border-blue-400 transition-colors">
				<div class="h-48 bg-gray-100 flex items-center justify-center">
					<span class="text-gray-400 group-hover:scale-110 transition-transform">Project 2 Image</span>
				</div>
				<div class="p-6">
					<h3 class="text-xl font-bold mb-2">E-commerce API</h3>
					<p class="text-gray-600 mb-4">A scalable REST API built with Node.js and PostgreSQL.</p>
					<div class="flex gap-2">
						<span class="px-2 py-1 bg-green-50 text-green-600 text-xs rounded font-medium">Node.js</span>
						<span class="px-2 py-1 bg-green-50 text-green-600 text-xs rounded font-medium">PostgreSQL</span>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
